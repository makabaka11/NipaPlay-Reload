platform :osx, '11.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

MEDIA_KIT_MACOS_FRAMEWORKS = %w[
  Ass
  Avcodec
  Avfilter
  Avformat
  Avutil
  Dav1d
  Freetype
  Fribidi
  Harfbuzz
  Mbedcrypto
  Mbedtls
  Mbedx509
  Mpv
  Png16
  Swresample
  Swscale
  Uchardet
  Xml2
].freeze

def patch_media_kit_macos_runner_support_files
  support_dir = File.join(__dir__, 'Pods', 'Target Support Files', 'Pods-Runner')
  framework_root = '${PODS_ROOT}/../Flutter/ephemeral/.symlinks/plugins/media_kit_libs_macos_video/macos/Frameworks'

  %w[Debug Profile Release].each do |config|
    input_path = File.join(support_dir, "Pods-Runner-frameworks-#{config}-input-files.xcfilelist")
    output_path = File.join(support_dir, "Pods-Runner-frameworks-#{config}-output-files.xcfilelist")

    next unless File.exist?(input_path) && File.exist?(output_path)

    input_lines = File.readlines(input_path, chomp: true)
    output_lines = File.readlines(output_path, chomp: true)

    MEDIA_KIT_MACOS_FRAMEWORKS.each do |name|
      input_entry = "#{framework_root}/#{name}.xcframework/macos-arm64_x86_64/#{name}.framework/#{name}"
      output_entry = "${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/#{name}.framework"

      input_lines << input_entry unless input_lines.include?(input_entry)
      output_lines << output_entry unless output_lines.include?(output_entry)
    end

    File.write(input_path, input_lines.join("\n") + "\n")
    File.write(output_path, output_lines.join("\n") + "\n")
  end

  script_path = File.join(support_dir, 'Pods-Runner-frameworks.sh')
  return unless File.exist?(script_path)

  anchor = '  install_framework "${BUILT_PRODUCTS_DIR}/media_kit_video/media_kit_video.framework"'
  injected_lines = MEDIA_KIT_MACOS_FRAMEWORKS.map do |name|
    %(  install_framework "#{framework_root}/#{name}.xcframework/macos-arm64_x86_64/#{name}.framework")
  end

  script_lines = File.readlines(script_path, chomp: true)
  filtered_lines = script_lines.reject { |line| injected_lines.include?(line) }

  rewritten_lines = []
  filtered_lines.each do |line|
    rewritten_lines << line
    rewritten_lines.concat(injected_lines) if line == anchor
  end

  File.write(script_path, rewritten_lines.join("\n") + "\n")
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  pod 'mdk', :podspec => '../third_party/podspecs/mdk.podspec.json'
  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
    
    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '11.0'
    end

    # Xcode 15+/16: 某些 Pod 会把 *.xcprivacy 当作源文件编译，导致 "no rule to process" 警告。
    # 这里将其从 Sources 移到 Resources，保持隐私清单仍会被打包进产物。
    if target.respond_to?(:source_build_phase) && target.respond_to?(:resources_build_phase)
      target.source_build_phase.files
        .select { |f| f.file_ref&.path&.end_with?('.xcprivacy') }
        .each do |build_file|
          target.resources_build_phase.add_file_reference(build_file.file_ref)
          build_file.remove_from_project
        end
    end
  end

  patch_media_kit_macos_runner_support_files
end
